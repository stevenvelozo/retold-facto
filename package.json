{
	"name": "retold-facto",
	"version": "0.2.0",
	"description": "Data warehouse and knowledge graph storage for the Retold ecosystem.",
	"main": "source/Retold-Facto.js",
	"bin": {
		"retold-facto": "bin/retold-facto.js"
	},
	"scripts": {
		"start": "node bin/retold-facto.js",
		"coverage": "npx quack coverage",
		"test": "npx quack test",
		"test-browser": "npx mocha test/Facto_Browser_Integration_tests.js -u tdd --exit --timeout 120000",
		"build": "npx quack build",
		"build-codemirror": "npx esbuild source/services/web-app/codemirror-entry.js --bundle --outfile=source/services/web-app/web/codemirror-bundle.js --format=iife --global-name=CodeMirrorModules --platform=browser --target=es2018",
		"build-test-model": "cd test && npx stricture -i model/ddl/Facto.ddl",
		"docker-build": "docker build -t retold-facto .",
		"docker-run": "docker run -p 8386:8386 retold-facto"
	},
	"mocha": {
		"spec": "test/RetoldFacto_tests.js",
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "5000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"lib/vendor"
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/stevenvelozo/retold-facto.git"
	},
	"keywords": [
		"data",
		"warehouse",
		"knowledge-graph",
		"certainty",
		"ingest"
	],
	"retoldBeacon": {
		"displayName": "Retold Facto",
		"description": "Data warehouse + knowledge graph storage with ingest / dataset / source CLI subcommands.",
		"category": "database",
		"mode": "standalone-service",
		"bin": "bin/retold-facto.js",
		"argTemplate": [
			"serve",
			"--port",
			{
				"fromLabPath": "Port"
			},
			"--config",
			{
				"fromLabPath": "ConfigPath"
			}
		],
		"healthCheck": {
			"path": "/"
		},
		"defaultPort": 8386,
		"requiresUltravisor": false,
		"configTemplate": {
			"APIServerPort": "{{Port}}",
			"SQLite": {
				"SQLiteFilePath": "{{BeaconDir}}/facto.sqlite"
			}
		},
		"configForm": {
			"Fields": []
		},
		"docker": {
			"image": "retold-facto",
			"dockerfile": "retold-facto.Dockerfile",
			"dataMountPath": "/app/data",
			"configMountPath": "/app/data/config.json",
			"exposedPort": 8386
		}
	},
	"author": "Steven Velozo <steven@velozo.com> (http://velozo.com/)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/stevenvelozo/retold-facto/issues"
	},
	"homepage": "https://github.com/stevenvelozo/retold-facto",
	"devDependencies": {
		"chai": "^6.2.2",
		"pict-docuserve": "^0.1.5",
		"puppeteer": "^24.40.0",
		"quackage": "^1.1.3",
		"stricture": "^4.0.2",
		"supertest": "^7.2.2"
	},
	"dependencies": {
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/state": "^6.6.0",
		"meadow-connection-sqlite": "^1.0.19",
		"@codemirror/view": "^6.41.0",
		"bibliograph": "^0.1.6",
		"codemirror": "^6.0.2",
		"fable": "^3.1.71",
		"fable-serviceproviderbase": "^3.0.19",
		"fast-xml-parser": "^5.5.10",
		"meadow": "^2.0.37",
		"meadow-connection-manager": "^1.1.0",
		"meadow-connection-mysql": "^1.0.18",
		"meadow-endpoints": "^4.0.17",
		"meadow-integration": "^1.0.38",
		"orator": "^6.1.0",
		"orator-serviceserver-restify": "^2.0.10",
		"orator-static-server": "^2.1.3",
		"pict": "^1.0.365",
		"pict-router": "^1.0.9",
		"pict-section-connection-form": "^0.0.1",
		"pict-section-flow": "^0.0.17",
		"pict-section-histogram": "^1.0.0",
		"pict-section-markdowneditor": "^1.0.10",
		"pict-section-modal": "^0.0.5",
		"pict-section-objecteditor": "^1.0.1",
		"stricture": "^4.0.2",
		"xlsx": "^0.18.5"
	}
}
